classDiagram
    %% PawPal+ system design (Phase 1 draft).
    %% Keep this file updated so it matches the final implementation.

    class Owner {
        +str name
        +int available_minutes
        +dict preferences
        +list~Pet~ pets
        +add_pet(pet Pet) None
        +all_tasks() list~Task~
    }

    class Pet {
        +str name
        +str species
        +str breed
        +list~Task~ tasks
        +add_task(task Task) None
        +remove_task(title str) None
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +str category
        +str preferred_time
        +bool recurring
        +priority_weight() int
    }

    class Scheduler {
        +int available_minutes
        +str day_start
        +build_plan(tasks list~Task~) list~PlanItem~
        +explain(plan list~PlanItem~) str
    }

    class PlanItem {
        +str start_time
        +Task task
    }

    Owner "1" --> "*" Pet : has
    Pet "1" --> "*" Task : has
    Scheduler ..> Task : schedules
    Scheduler ..> PlanItem : produces
    PlanItem "1" --> "1" Task : wraps
