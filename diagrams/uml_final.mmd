classDiagram
    %% PawPal+ FINAL system design — matches pawpal_system.py after Phases 2-5.
    %% Changes since the Phase 1 draft:
    %%   - Task gained completion status, recurrence (frequency + due_date),
    %%     is_recurring(), and next_occurrence().
    %%   - Scheduler gained the algorithmic layer: sort_by_time, filter_by_status,
    %%     find_conflicts, and complete_task (which reschedules recurring tasks).
    %%   - Owner gained tasks_for_pet(); PlanItem was added to carry plan timing.

    class Owner {
        +str name
        +int available_minutes
        +dict preferences
        +list~Pet~ pets
        +add_pet(pet Pet) None
        +all_tasks() list~Task~
        +tasks_for_pet(name str) list~Task~
    }

    class Pet {
        +str name
        +str species
        +str breed
        +list~Task~ tasks
        +add_task(task Task) None
        +remove_task(title str) None
        +task_count() int
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +str category
        +str preferred_time
        +str frequency
        +date due_date
        +bool completed
        +priority_weight() int
        +mark_complete() None
        +mark_incomplete() None
        +is_recurring() bool
        +next_occurrence() Task
    }

    class Scheduler {
        +int available_minutes
        +str day_start
        +build_plan(tasks list~Task~) list~PlanItem~
        +sort_by_time(tasks list~Task~) list~Task~
        +filter_by_status(tasks list~Task~, completed bool) list~Task~
        +find_conflicts(tasks list~Task~) list~str~
        +next_available_slot(tasks list~Task~, duration int) str
        +complete_task(pet Pet, task Task) Task
        +explain(plan list~PlanItem~) str
    }

    class PlanItem {
        +str start_time
        +Task task
    }

    Owner "1" --> "*" Pet : has
    Pet "1" --> "*" Task : has
    Scheduler ..> Task : schedules
    Scheduler ..> Pet : reschedules recurring
    Scheduler ..> PlanItem : produces
    PlanItem "1" --> "1" Task : wraps
